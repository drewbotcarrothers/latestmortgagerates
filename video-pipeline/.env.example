# OpenMontage API Keys Configuration
# Add your keys below and rename this file to .env
# OpenMontage supports both free and paid providers - add what you have

# =============================================================================
# REQUIRED: YouTube Upload (existing pipeline)
# =============================================================================
YOUTUBE_CLIENT_SECRET=your-google-client-secret-json-content-here
YOUTUBE_REFRESH_TOKEN=your-youtube-refresh-token-here

# =============================================================================
# IMAGE + VIDEO GENERATION (pick at least one)
# =============================================================================
# FAL: FLUX images + Google Veo, Kling, MiniMax video + Recraft images
FAL_KEY=your-fal-key-here

# Kling official direct API (alternative to FAL)
KLING_API_KEY=your-kling-key-here
KLING_API_BASE_URL= # Optional; default Singapore API endpoint

# =============================================================================
# FREE STOCK MEDIA (get free developer keys)
# =============================================================================
PEXELS_API_KEY=your-pexels-key-here
PIXABAY_API_KEY=your-pixabay-key-here
UNSPLASH_ACCESS_KEY=your-unsplash-key-here

# =============================================================================
# VOICE / NARRATION (pick at least one)
# =============================================================================
# ElevenLabs: Premium TTS, AI music, sound effects
ELEVENLABS_API_KEY=your-elevenlabs-key-here

# OpenAI: TTS, GPT Image 2 images
OPENAI_API_KEY=your-openai-key-here

# Google: 700+ voices
GOOGLE_API_KEY=your-google-key-here

# xAI: Grok image edits/generation + video
XAI_API_KEY=your-xai-key-here

# =============================================================================
# MUSIC (optional)
# =============================================================================
# Suno: Full songs, instrumentals, any genre
SUNO_API_KEY=your-suno-key-here

# =============================================================================
# MORE VIDEO PROVIDERS (optional)
# =============================================================================
# HeyGen: VEO, Sora, Runway, Kling via single gateway
HEYGEN_API_KEY=your-heygen-key-here

# Runway: Gen-4 direct
RUNWAY_API_KEY=your-runway-key-here

# =============================================================================
# LOCAL GPU (optional - free video generation)
# =============================================================================
# Set to true if you have a GPU and want free local video generation
VIDEO_GEN_LOCAL_ENABLED=false
VIDEO_GEN_LOCAL_MODEL=wan2.1-1.3b # or wan2.1-14b, hunyuan-1.5, ltx2-local, cogvideo-5b

# =============================================================================
# HYBRID PIPELINE: Rate Card Video Settings
# =============================================================================
# Your existing rate card pipeline settings
RATE_CARD_BG_COLOR=#0f172a
RATE_CARD_ACCENT_COLOR=#0d9488
RATE_CARD_FONT=Inter
RATE_CARD_MUSIC_STYLE=corporate-upbeat
RATE_CARD_VOICE=nova
RATE_CARD_DURATION_SHORT=15
RATE_CARD_DURATION_CARDS=25
RATE_CARD_DURATION_MONTHLY=90
